{
  "name": "bmz-ir",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "TMPDIR=/tmp nuxt dev",
    "db:new": "supabase migration new",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:types": "supabase gen types typescript --local > bmz-ir-web/shared/types/database.types.ts",
    "db:types:remote": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" --schema public > bmz-ir-web/shared/types/database.types.ts",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test:ir": "bun test bmz-ir-web/server/services/ir.test.ts",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@nuxthub/core": "^0.10.0",
    "@nuxt/ui": "4.8.1",
    "@nuxtjs/supabase": "^2.0.9",
    "drizzle-orm": "^0.45.0",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt": "^4.4.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3 || ^6.0.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/eslint": "^1.15.2",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.8",
    "prettier": "3.8.3",
    "supabase": "^2.104.0",
    "vue-tsc": "^3.3.3"
  },
  "overrides": {
    "chokidar": "3.6.0",
    "vite": "^8.0.0",
    "vue": "3.6.0-beta.13"
  }
}
