{
  "name": "bmz-ir",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "cf:build": "NITRO_PRESET=cloudflare_module nuxt build",
    "cf:deploy": "bun run cf:build && wrangler deploy --config .output/server/wrangler.json",
    "cf:types": "bun run cf:build && mkdir -p bmz-ir-web/shared/types && wrangler types bmz-ir-web/shared/types/worker-configuration.d.ts --config .output/server/wrangler.json --include-runtime false",
    "dev": "TMPDIR=/tmp nuxt dev",
    "db:generate": "nuxt db generate",
    "db:migrate": "nuxt db migrate",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test:ir": "bun test bmz-ir-web/server/services/ir.test.ts",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@nuxthub/core": "^0.10.0",
    "@nuxt/ui": "4.8.1",
    "drizzle-orm": "^0.45.0",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt": "^4.4.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3 || ^6.0.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/eslint": "^1.15.2",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.8",
    "prettier": "3.8.3",
    "vue-tsc": "^3.3.3",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "chokidar": "3.6.0",
    "vite": "^8.0.0",
    "vue": "3.6.0-beta.13"
  }
}
