# Server-only secrets. Never expose these to the browser.
NUXT_SESSION_PASSWORD=
NUXT_IR_PROVIDER_KEY=

# Cloudflare deployment. Create the D1 database and R2 bucket first, then fill
# the real D1 database ID before deploying.
CLOUDFLARE_WORKER_NAME=bmz-ir-web
NUXT_HUB_CLOUDFLARE_DATABASE_NAME=bmz-ir-db
NUXT_HUB_CLOUDFLARE_DATABASE_ID=
NUXT_HUB_BLOB_BUCKET=bmz-ir-blob
NUXT_HUB_CLOUDFLARE_ACCOUNT_ID=
NUXT_HUB_CLOUDFLARE_API_TOKEN=
